{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Ansumansahoo/image-transformer/schemas/preset.schema.json",
  "title": "Preset",
  "description": "A single swatch-generator preset. All fields optional; missing fields keep the current UI value.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "shape": {
      "type": "string",
      "enum": ["square", "circle", "rounded", "pill", "oval", "diamond", "hexagon", "color"],
      "description": "Swatch shape / mask"
    },
    "sizes": {
      "type": "string",
      "pattern": "^\\d+(,\\d+)*$",
      "description": "Comma-separated output sizes in pixels, e.g. '64,128,256'"
    },
    "ratioW": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Width part of aspect ratio"
    },
    "ratioH": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Height part of aspect ratio"
    },
    "cropEngine": {
      "type": "string",
      "enum": ["smart", "center", "contain", "cover", "stretch"],
      "description": "Crop algorithm"
    },
    "bgThresh": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255,
      "description": "Background detection threshold (0-255). Pixels above this value in all channels are treated as background."
    },
    "cropPad": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Padding around detected product area, percent of detected bounding box size"
    },
    "bgMode": {
      "type": "string",
      "enum": ["transparent", "white", "black", "custom", "gradient", "solid"],
      "description": "Background fill mode. 'solid' is a legacy alias for 'custom' and will be normalized on load."
    },
    "bgColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?$",
      "description": "Primary background hex color (used for custom/solid/gradient start)"
    },
    "bgColor2": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?$",
      "description": "Gradient end color"
    },
    "shadow": {
      "type": "string",
      "enum": ["none", "soft", "medium", "strong", "floating"],
      "description": "Drop shadow preset"
    },
    "borderMode": {
      "type": "string",
      "enum": ["none", "solid", "rounded"],
      "description": "Border style. 'none' suppresses all border drawing regardless of borderWidth."
    },
    "borderWidth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20,
      "description": "Border thickness in pixels (ignored when borderMode is 'none')"
    },
    "borderColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{3}([0-9a-fA-F]{3})?$",
      "description": "Border color"
    },
    "format": {
      "type": "string",
      "enum": ["image/png", "image/jpeg", "image/webp", "png", "jpeg", "webp"],
      "description": "Output MIME type or short name. MIME forms are legacy; short names are canonical."
    },
    "quality": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "JPEG/WebP quality (1-100). Ignored for PNG."
    },
    "nameTemplate": {
      "type": "string",
      "description": "Output filename template. Tokens: {basename} {shape} {size} {index}"
    },
    "zipLayout": {
      "type": "string",
      "enum": ["flat", "by-product", "by-size"],
      "description": "ZIP archive folder structure"
    }
  }
}
